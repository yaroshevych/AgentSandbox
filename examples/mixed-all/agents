#!/usr/bin/env bash
# Generated by AgentSandbox
set -euo pipefail

IMAGE=agentsandbox
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

ensure_image() {
    if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
        echo "==> Building $IMAGE (first run — this takes a few minutes)..."
        docker build -t "$IMAGE" -f "$SCRIPT_DIR/Dockerfile" "$SCRIPT_DIR"
    fi
}

run() {
    ensure_image
    docker run --rm -it \
        -v "$(pwd):/workspace:cached" \
        -v agentsandbox-cache:/cache \
        -v "$HOME/.claude:/home/node/.claude:ro" \
        -v "$HOME/.claude.json:/home/node/.claude.json:ro" \
        -v "$HOME/.codex:/home/node/.codex:ro" \
        -v "$HOME/.pi:/home/node/.pi:ro" \
        -v "$HOME/.opencode:/home/node/.opencode:ro" \
        -v "$HOME/.config/opencode:/home/node/.config/opencode:ro" \
        -v "$HOME/.local/share/opencode:/home/node/.local/share/opencode:ro" \
        -v "$HOME/.local/state/opencode:/home/node/.local/state/opencode:ro" \
        -w /workspace \
        "$IMAGE" "$@"
}

case "${1:-}" in
    claude)   shift; run claude "$@" ;;
    codex)    shift; run codex "$@" ;;
    pi)       shift; run pi "$@" ;;
    opencode) shift; run opencode "$@" ;;
    shell|"") run bash ;;
    *)        echo "Warning: unknown command '$1', dropping into shell" >&2; run bash ;;
esac
